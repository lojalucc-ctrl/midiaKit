# Use as strings do POOLER do Supabase (Settings -> Database -> Connection pooling).
# DATABASE_URL = Transaction pooler (6543) | DIRECT_URL = Session pooler (5432)
# Usuário no pooler: postgres.<PROJECT_REF>
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<SENHA>@aws-0-<REGIAO>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<PROJECT_REF>:<SENHA>@aws-0-<REGIAO>.pooler.supabase.com:5432/postgres"

PORT=3333
NODE_ENV=development

JWT_SECRET="troque-por-uma-chave-aleatoria-longa"
ENCRYPTION_KEY="chave-de-32-bytes-para-o-aes-256"

FRONTEND_URL="http://localhost:3000"
COOKIE_DOMAIN="localhost"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
META_CLIENT_ID=""
META_CLIENT_SECRET=""
