# Copie para `.env` e preencha. O docker-compose le este arquivo.

# Banco (Supabase) — use o POOLER (Settings -> Database -> Connection pooling).
DATABASE_URL="postgresql://postgres.<REF>:<SENHA>@aws-1-<REGIAO>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<REF>:<SENHA>@aws-1-<REGIAO>.pooler.supabase.com:5432/postgres"

NEXT_PUBLIC_SUPABASE_URL="https://<REF>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<PUBLISHABLE_OU_ANON_KEY>"

JWT_SECRET="troque-por-uma-chave-aleatoria-longa"
ENCRYPTION_KEY="chave-de-32-bytes-para-o-aes-256"

FRONTEND_URL="http://localhost:3000"
BACKEND_PUBLIC_URL="http://localhost:3333"
COOKIE_DOMAIN="localhost"

# OAuth Google — credenciais do Google Cloud Console (tipo "Web application").
# Adicione o redirect URI abaixo em "Authorized redirect URIs".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3333/auth/google/callback"
YOUTUBE_REDIRECT_URI="http://localhost:3333/integrations/youtube/callback"

# OAuth Meta/Instagram — App ID/Secret do app na Meta for Developers.
# Adicione o redirect URI abaixo em "Valid OAuth Redirect URIs".
META_CLIENT_ID=""
META_CLIENT_SECRET=""
META_REDIRECT_URI="http://localhost:3333/integrations/instagram/callback"
META_GRAPH_VERSION="v23.0"
