# URL pública do backend (Render). Ex.: https://midiakit-backend.onrender.com
NEXT_PUBLIC_API_URL=
# Mesmo valor (usado por Server Components ao chamar o backend)
API_INTERNAL_URL=
# 0 = usa o backend real (padrão). 1 = dados mockados (sem backend).
NEXT_PUBLIC_USE_MOCK=0
# Supabase client (opcional)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
